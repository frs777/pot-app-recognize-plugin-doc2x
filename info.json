{
  "id": "plugin.com.pot-app.doc2x",
  "plugin_type": "recognize",
  "icon": "icon.png",
  "display": "Doc2X OCR",
  "homepage": "https://github.com/pot-app/pot-app-recognize-plugin-doc2x",
  "needs": [
    { "key": "token", "display": "Doc2X API Token", "type": "input" },
    {
      "key": "mathFormat",
      "display": "数学公式格式",
      "type": "select",
      "options": {
        "latex": "LaTeX 标准格式 \\(...\\)",
        "obsidian": "Obsidian 格式 $...$"
      }
    },
    {
      "key": "showDebug",
      "display": "调试模式",
      "type": "select",
      "options": {
        "false": "关闭",
        "true": "开启 (显示完整 API 响应)"
      }
    }
  ],
  "language": {
    "auto": "auto",
    "zh_cn": "zh",
    "zh_tw": "zh",
    "en": "en",
    "ja": "ja",
    "ko": "ko",
    "fr": "fr",
    "es": "es",
    "ru": "ru",
    "de": "de",
    "it": "it",
    "pt_pt": "pt",
    "pt_br": "pt",
    "vi": "vi",
    "th": "th",
    "ar": "ar"
  }
}
